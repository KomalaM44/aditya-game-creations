{
  "name": "aditya-game-creations",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "games/*"
  ],
  "scripts": {
    "build": "npm run build --workspace aditya-base-survival && npm run build --workspace build-your-space-shuttle && npm run build --workspace cozy-watchtower-survival && npm run build --workspace geometry-run && npm run build --workspace obby-123 && npm run build --workspace forest-camp-survival",
    "preview:site": "vite docs --host 127.0.0.1",
    "dev:base": "npm run dev --workspace aditya-base-survival",
    "dev:shuttle": "npm run dev --workspace build-your-space-shuttle",
    "dev:cozy": "npm run dev --workspace cozy-watchtower-survival",
    "dev:geometry": "npm run dev --workspace geometry-run",
    "dev:obby": "npm run dev --workspace obby-123",
    "dev:forest": "npm run dev --workspace forest-camp-survival"
  },
  "dependencies": {
    "three": "^0.177.0"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
